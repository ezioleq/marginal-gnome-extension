{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "outDir": "./dist",
        "sourceMap": false,
        "strict": true,
        "skipLibCheck": true,
        "target": "es2023",
        "lib": [
            "ES2023"
        ],
        "experimentalDecorators": true,
        "useDefineForClassFields": false
    },
    "include": [
        "ambient.d.ts",
    ],
    "files": [
        "extension.ts",
        "prefs.ts",
        "lib/searchProvider.ts"
    ],
}